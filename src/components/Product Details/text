<div className="productdisplay">
            <NavBar/>
        <div className="cont">
            <div className="row">
                <div className="col-md-6">
                    <div id="productCarousel" className="carousel" data-ride="carousel">
                        <div className="carousel-inner c-img">
                            {productImages.map((proimage, index) => (
                                <div key={index} className='carousel-item'>
                                    <img
                                        className="d-block w-100 img"
                                        src={`http://localhost:7230/uploads/${proimage}`}
                                        alt={`Product Image ${index + 1}`}
                                    />
                                </div>
                               
                               
                               
                            ))}
                        </div>
                        <a className="carousel-control-prev left" href="#productCarousel" role="button" data-slide="prev">
                            <span className="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span className="sr-only">Previous</span>
                        </a>
                        <a className="carousel-control-next right" href="#productCarousel" role="button" data-slide="next">
                            <span className="carousel-control-next-icon" aria-hidden="true"></span>
                            <span className="sr-only">Next</span>
                        </a>
                    </div>
                </div>
                <div className="col-md-6 details">
                    <h2>{product.Pname}</h2>
                    <p>{product.description}</p>
                    <h5>Gender : {product.gender}</h5>
                    <h4 style={{textDecoration:'line-through', textDecorationColor:'red', color:'red'}}>RS : &#8377;{product.originalprice}</h4>
                    <h4>RS : &#8377;{product.offerprice}</h4>
                    <button className="btn btn-primary">Add to Cart</button>
                </div>
            </div>
            <div className="row mt-5">
                <h4>Suggested Products</h4 >
                {suggestedProducts.map((suggestedProduct) => (
                    <div className="col-md-4 my-3" key={suggestedProduct.id}>
                        <Card>
                            <img
                                className="img-top s-img"
                                src={`http://localhost:7230/uploads/${product.image}`}
                                alt={suggestedProduct.name}
                            />
                            <div className="card-body">
                                <h5 className="card-title">{suggestedProduct.Pname}</h5>
                                <a href={`/product/${suggestedProduct.id}`} className="btn btn-link">
                                    View Details
                                </a>
                            </div>
                        </Card>
                    </div>
                ))}
            </div>
        </div>
        </div>